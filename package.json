{
  "name": "@eclipse-daanse/tsm",
  "version": "0.0.1-next.1",
  "description": "TypeScript Module System - Runtime module loading with dependency management, lifecycle hooks, and hot reload",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "demo": "vite",
    "demo:build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "prepare": "husky"
  },
  "keywords": [
    "typescript",
    "modules",
    "federation",
    "plugin",
    "dependency-injection",
    "lifecycle",
    "hot-reload"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-daanse/org.eclipse.daanse.tsm.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "semver": "^7.7.3"
  }
}
